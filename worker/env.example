# Worker env example (copy to .env)

DATABASE_URL=postgresql://teamhub:teamhub@localhost:5432/teamhub?schema=public
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible storage (used by blob cleanup jobs)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=teamhub
MINIO_SECRET_KEY=teamhub-secret
MINIO_BUCKET=teamhub
MINIO_BUCKET_PUBLIC=teamhub-public

# Must match backend cache key prefix (only used for bumping cache version)
CACHE_PREFIX=cache:v1

# Email (optional, for reminders)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Formatting
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Blob sweeper
# Orphan objects must be older than this before deletion
BLOB_SWEEP_ORPHAN_GRACE_DAYS=7
# Delete chat attachment objects whose DB rows are unlinked (message deleted)
# and older than this many hours.
BLOB_SWEEP_CHAT_UNLINKED_HOURS=24

# Optional
ACTIVITY_RETENTION_DAYS=90
