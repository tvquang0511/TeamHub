{
  "info": {
    "_postman_id": "3b9c2d1b-9d4b-4c67-8c65-9b31c5481f90",
    "name": "TeamHub - 60 Attachments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "List by card",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/attachments/cards/{{cardId}}",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "cards", "{{cardId}}"]
        }
      }
    },
    {
      "name": "Presign upload (PUT URL)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/attachments/cards/{{cardId}}/presign",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "cards", "{{cardId}}", "presign"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fileName\": \"hello.txt\",\n  \"mimeType\": \"text/plain\",\n  \"size\": 12\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "if (json.presign && json.presign.objectKey) pm.collectionVariables.set('objectKey', json.presign.objectKey);",
              "if (json.presign && json.presign.bucket) pm.collectionVariables.set('bucket', json.presign.bucket);",
              "if (json.presign && json.presign.url) pm.collectionVariables.set('objectUrl', json.presign.url);",
              "if (json.presign && json.presign.uploadUrl) pm.collectionVariables.set('uploadUrl', json.presign.uploadUrl);"
            ]
          }
        }
      ]
    },
    {
      "name": "Commit file attachment (after upload)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/attachments/cards/{{cardId}}/files",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "cards", "{{cardId}}", "files"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bucket\": \"{{bucket}}\",\n  \"objectKey\": \"{{objectKey}}\",\n  \"url\": \"{{objectUrl}}\",\n  \"fileName\": \"hello.txt\",\n  \"mimeType\": \"text/plain\",\n  \"size\": 12\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.attachment && json.attachment.id) pm.collectionVariables.set('attachmentId', json.attachment.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create link attachment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/attachments/cards/{{cardId}}/links",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "cards", "{{cardId}}", "links"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"linkUrl\": \"https://example.com/article\",\n  \"linkTitle\": \"Example Article\"\n}"
        }
      }
    },
    {
      "name": "Create card reference attachment (uses refCardId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/attachments/cards/{{cardId}}/cards",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "cards", "{{cardId}}", "cards"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"referencedCardId\": \"{{refCardId}}\",\n  \"linkTitle\": \"Related card\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.attachment && json.attachment.id) pm.collectionVariables.set('attachmentId', json.attachment.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Presign download",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/attachments/{{attachmentId}}/presign-download",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "{{attachmentId}}", "presign-download"]
        }
      }
    },
    {
      "name": "Delete attachment",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/attachments/{{attachmentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["attachments", "{{attachmentId}}"]
        }
      }
    }
  ]
}
