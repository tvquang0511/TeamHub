{
  "info": {
    "_postman_id": "a2aa4f1c-5d4b-4d93-9f6f-f8c3f8a8d040",
    "name": "TeamHub - 40 Lists",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "Create (captures listId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/lists", "host": ["{{baseUrl}}"], "path": ["lists"] },
        "body": { "mode": "raw", "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"name\": \"Todo\"\n}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.list && json.list.id) pm.collectionVariables.set('listId', json.list.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "List (by boardId)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/lists?boardId={{boardId}}",
          "host": ["{{baseUrl}}"],
          "path": ["lists"],
          "query": [{ "key": "boardId", "value": "{{boardId}}" }]
        }
      }
    },
    {
      "name": "Move / reorder (prev/next)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/lists/{{listId}}/move", "host": ["{{baseUrl}}"], "path": ["lists", "{{listId}}", "move"] },
        "body": { "mode": "raw", "raw": "{\n  \"prevId\": null,\n  \"nextId\": null\n}" }
      }
    }
    ,
    {
      "name": "Delete (archive)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/lists/{{listId}}", "host": ["{{baseUrl}}"], "path": ["lists", "{{listId}}"]
        }
      }
    }
  ]
}
