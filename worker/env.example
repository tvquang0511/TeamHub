# Worker env example (copy to .env)

DATABASE_URL=postgresql://teamhub:teamhub@localhost:5432/teamhub?schema=public
REDIS_URL=redis://localhost:6379

# Must match backend cache key prefix (only used for bumping cache version)
CACHE_PREFIX=cache:v1

# Email (optional, for reminders)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Formatting
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Optional
ACTIVITY_RETENTION_DAYS=90
