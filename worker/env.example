# Worker environment example
# Copy to worker/.env (gitignored) and fill values.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamhub?schema=public
REDIS_URL=redis://localhost:6379

# Cache key prefix (shared with backend)
CACHE_PREFIX=cache:v1

# Optional SMTP (reminders/emails)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Formatting
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Retention
ACTIVITY_RETENTION_DAYS=90
