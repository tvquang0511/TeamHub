{
  "info": {
    "_postman_id": "3c5e56db-ff0b-4f64-9c7a-4f3a4f9a9d17",
    "name": "TeamHub - 52 Checklists",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "checklistId", "value": "" },
    { "key": "itemId", "value": "" }
  ],
  "item": [
    {
      "name": "List by card",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/checklists/cards/{{cardId}}/checklists",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "cards", "{{cardId}}", "checklists"]
        }
      }
    },
    {
      "name": "Create checklist (captures checklistId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/checklists/cards/{{cardId}}/checklists",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "cards", "{{cardId}}", "checklists"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Checklist A\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.checklist && json.checklist.id) pm.collectionVariables.set('checklistId', json.checklist.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Update checklist",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/checklists/checklists/{{checklistId}}",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "checklists", "{{checklistId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Checklist A (updated)\"\n}"
        }
      }
    },
    {
      "name": "Create item (captures itemId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/checklists/checklists/{{checklistId}}/items",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "checklists", "{{checklistId}}", "items"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Item 1\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.item && json.item.id) pm.collectionVariables.set('itemId', json.item.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Update item",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/checklists/items/{{itemId}}",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "items", "{{itemId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isDone\": true\n}"
        }
      }
    },
    {
      "name": "Delete item",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/checklists/items/{{itemId}}",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "items", "{{itemId}}"]
        }
      }
    },
    {
      "name": "Delete checklist",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/checklists/checklists/{{checklistId}}",
          "host": ["{{baseUrl}}"],
          "path": ["checklists", "checklists", "{{checklistId}}"]
        }
      }
    }
  ]
}
