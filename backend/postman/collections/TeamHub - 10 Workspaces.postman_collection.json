{
  "info": {
    "_postman_id": "a2aa4f1c-5d4b-4d93-9f6f-f8c3f8a8d010",
    "name": "TeamHub - 10 Workspaces",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "Create (captures workspaceId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] },
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Workspace\"\n}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.workspace && json.workspace.id) pm.collectionVariables.set('workspaceId', json.workspace.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "List mine",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
      }
    },
    {
      "name": "Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}"] }
      }
    },
    {
      "name": "Members",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "members"] }
      }
    },
    {
      "name": "Update member role (OWNER/ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{memberUserId}}",
          "host": ["{{baseUrl}}"],
          "path": ["workspaces", "{{workspaceId}}", "members", "{{memberUserId}}"]
        },
        "body": { "mode": "raw", "raw": "{\n  \"role\": \"ADMIN\"\n}" }
      }
    },
    {
      "name": "Remove member (OWNER/ADMIN)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{memberUserId}}",
          "host": ["{{baseUrl}}"],
          "path": ["workspaces", "{{workspaceId}}", "members", "{{memberUserId}}"]
        }
      }
    },
    {
      "name": "Leave workspace (current user)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/leave",
          "host": ["{{baseUrl}}"],
          "path": ["workspaces", "{{workspaceId}}", "leave"]
        }
      }
    }
  ]
}
