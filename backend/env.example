# Backend env example (copy to .env)

# Server
NODE_ENV=development
PORT=4000

# Data retention
ACTIVITY_RETENTION_DAYS=90

# Postgres
DATABASE_URL=postgresql://teamhub:teamhub@localhost:5432/teamhub?schema=public

# Redis (BullMQ + Cache)
REDIS_URL=redis://localhost:6379

# Cache
CACHE_ENABLED=true
# Prefix for ALL Redis cache keys (keep separate from BullMQ internal keys)
CACHE_PREFIX=cache:v1
# Cache TTLs (seconds)
CACHE_ANALYTICS_TTL_SEC=600
CACHE_MEMBERSHIP_TTL_SEC=60
CACHE_BOARD_VIEW_TTL_SEC=120
CACHE_CARD_DETAIL_TTL_SEC=60

# Cache logs (debug)
# Enable when you want to observe HIT/MISS/SET/DEL events.
CACHE_LOG_ENABLED=false
# Log sampling rate 0..1 (e.g. 0.05 = ~5% of cache operations)
CACHE_LOG_SAMPLE_RATE=0.0
# Log full Redis keys (may include IDs)
CACHE_LOG_KEYS=false

# Rate limiting (Redis)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PREFIX=rl:v1

# Global API safety net (per IP)
RATE_LIMIT_API_WINDOW_SEC=60
RATE_LIMIT_API_MAX=600

# Feature-level limits (prefer per user when authenticated)
RATE_LIMIT_WORKSPACES_WINDOW_SEC=60
RATE_LIMIT_WORKSPACES_MAX=60

RATE_LIMIT_INVITES_WINDOW_SEC=60
RATE_LIMIT_INVITES_MAX=30

RATE_LIMIT_BOARDS_WINDOW_SEC=60
RATE_LIMIT_BOARDS_MAX=120

# Board view (GET /boards/:id/detail) is heavier
RATE_LIMIT_BOARD_VIEW_WINDOW_SEC=60
RATE_LIMIT_BOARD_VIEW_MAX=30

# Board chat (GET/POST /boards/:id/messages...)
RATE_LIMIT_CHAT_WINDOW_SEC=60
RATE_LIMIT_CHAT_MAX=90

RATE_LIMIT_LISTS_WINDOW_SEC=60
RATE_LIMIT_LISTS_MAX=120

RATE_LIMIT_CARDS_WINDOW_SEC=60
RATE_LIMIT_CARDS_MAX=180

# Card detail (GET /cards/:id) is heavier
RATE_LIMIT_CARD_DETAIL_WINDOW_SEC=60
RATE_LIMIT_CARD_DETAIL_MAX=90

RATE_LIMIT_USERS_WINDOW_SEC=60
RATE_LIMIT_USERS_MAX=60

# Upload/presign endpoints should be stricter
RATE_LIMIT_ATTACHMENTS_WINDOW_SEC=60
RATE_LIMIT_ATTACHMENTS_MAX=30

RATE_LIMIT_LABELS_WINDOW_SEC=60
RATE_LIMIT_LABELS_MAX=90

RATE_LIMIT_CHECKLISTS_WINDOW_SEC=60
RATE_LIMIT_CHECKLISTS_MAX=90

RATE_LIMIT_ASSIGNEES_WINDOW_SEC=60
RATE_LIMIT_ASSIGNEES_MAX=90

RATE_LIMIT_COMMENTS_WINDOW_SEC=60
RATE_LIMIT_COMMENTS_MAX=120

RATE_LIMIT_ANALYTICS_WINDOW_SEC=60
RATE_LIMIT_ANALYTICS_MAX=30

# Auth endpoints are more sensitive (per IP)
RATE_LIMIT_AUTH_WINDOW_SEC=60
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PASSWORD_WINDOW_SEC=3600
RATE_LIMIT_PASSWORD_MAX=5

# CORS
CORS_ORIGIN=http://localhost:5173

# Socket.IO Admin UI (development only)
# Usage: open https://admin.socket.io, set server URL to http://localhost:4000
# Add https://admin.socket.io to CORS_ORIGIN if you enable this.
SOCKET_ADMIN_UI_ENABLED=false
SOCKET_ADMIN_UI_ORIGIN=https://admin.socket.io
SOCKET_ADMIN_UI_USERNAME=admin
SOCKET_ADMIN_UI_PASSWORD=admin
# NOTE: password can be plain text; the server will bcrypt-hash it for Admin UI.

# Reverse proxy
# Set true when behind Nginx so req.ip uses X-Forwarded-For (recommended in docker-compose/nginx).
TRUST_PROXY=false

# Public web URL (used in emails)
APP_WEB_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookies
AUTH_COOKIE_NAME=teamhub_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Bcrypt
BCRYPT_ROUNDS=10

# MinIO (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
# Public endpoint used for presigned URLs and public asset URLs.
# - If you run everything behind Nginx (single origin on http://localhost), set:
#   MINIO_PUBLIC_ENDPOINT=http://localhost
# - If you access MinIO directly (dev compose exposing 9000), set:
#   MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=teamhub
MINIO_SECRET_KEY=teamhub-secret
MINIO_REGION=us-east-1
MINIO_BUCKET=teamhub
MINIO_BUCKET_PUBLIC=teamhub-public

# Analytics seed (optional; used by `npm run seed:analytics`)
ANALYTICS_SEED_DAYS=30
ANALYTICS_SEED_BOARD_NAME=Analytics Seed Board
SEED_ANALYTICS_BACKFILL=1
SEED_ANALYTICS_RESET=0

# Blob sweeper (optional; cleans orphaned objects in MinIO)
BLOB_SWEEP_ENABLED=true
BLOB_SWEEP_CRON=30 1 * * *
BLOB_SWEEP_TZ=UTC

# Delay before running delete_object (ms)
BLOB_DELETE_DELAY_MS=60000
