# Backend environment example
# Copy to backend/.env (gitignored) and fill values.

# Server
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamhub?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Cache (Redis)
CACHE_ENABLED=true
CACHE_PREFIX=cache:v1
CACHE_ANALYTICS_TTL_SEC=600
CACHE_MEMBERSHIP_TTL_SEC=60
CACHE_BOARD_VIEW_TTL_SEC=120
CACHE_CARD_DETAIL_TTL_SEC=60

# CORS
CORS_ORIGIN=http://localhost:5173

# Public web URL
APP_WEB_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Auth cookies
AUTH_COOKIE_NAME=teamhub_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# BCrypt
BCRYPT_ROUNDS=10

# MinIO / S3
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=teamhub
MINIO_BUCKET_PUBLIC=teamhub-public
