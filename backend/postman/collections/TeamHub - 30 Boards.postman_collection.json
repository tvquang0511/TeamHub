{
  "info": {
    "_postman_id": "a2aa4f1c-5d4b-4d93-9f6f-f8c3f8a8d030",
    "name": "TeamHub - 30 Boards",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "Create (captures boardId)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/boards", "host": ["{{baseUrl}}"], "path": ["boards"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"name\": \"My Board\",\n  \"description\": \"Board for MVP\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.board && json.board.id) pm.collectionVariables.set('boardId', json.board.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "List (by workspaceId)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/boards?workspaceId={{workspaceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["boards"],
          "query": [{ "key": "workspaceId", "value": "{{workspaceId}}" }]
        }
      }
    },
    {
      "name": "Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}"] }
      }
    },
    {
      "name": "Get detail (one-shot)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}/detail", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}", "detail"] }
      }
    },
    {
      "name": "Delete (archive)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}"] }
      }
    },
    {
      "name": "Members - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}/members", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}", "members"] }
      }
    },
    {
      "name": "Members - Add by userId",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}/members", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}", "members"] },
        "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"MEMBER\"\n}" }
      }
    },
    {
      "name": "Members - Add by email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/boards/{{boardId}}/members/by-email", "host": ["{{baseUrl}}"], "path": ["boards", "{{boardId}}", "members", "by-email"] },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{inviteEmail}}\",\n  \"role\": \"MEMBER\"\n}" }
      }
    }
  ]
}
