{
  "info": {
    "_postman_id": "b2aa4f1c-5d4b-4d93-9f6f-f8c3f8a8d005",
    "name": "TeamHub - 05 Users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "Get me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["users", "me"]
        }
      }
    },
    {
      "name": "Update me",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["users", "me"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"displayName\": \"{{displayName}}\",\n  \"description\": \"{{userDescription}}\"\n}"
        }
      }
    },
    {
      "name": "Avatar: init upload (captures avatarObjectKey/avatarUploadUrl)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/me/avatar/init",
          "host": ["{{baseUrl}}"],
          "path": ["users", "me", "avatar", "init"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fileName\": \"avatar.png\",\n  \"contentType\": \"image/png\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "if (json.upload && json.upload.objectKey) pm.collectionVariables.set('avatarObjectKey', json.upload.objectKey);",
              "if (json.upload && json.upload.uploadUrl) pm.collectionVariables.set('avatarUploadUrl', json.upload.uploadUrl);"
            ]
          }
        }
      ]
    },
    {
      "name": "Avatar: commit upload (uses avatarObjectKey)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/me/avatar/commit",
          "host": ["{{baseUrl}}"],
          "path": ["users", "me", "avatar", "commit"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"objectKey\": \"{{avatarObjectKey}}\"\n}"
        }
      }
    },
    {
      "name": "Search users (global)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/users/search?q={{searchQ}}&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["users", "search"],
          "query": [
            { "key": "q", "value": "{{searchQ}}" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Search users (workspace scoped)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/users/search?q={{searchQ}}&workspaceId={{workspaceId}}&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["users", "search"],
          "query": [
            { "key": "q", "value": "{{searchQ}}" },
            { "key": "workspaceId", "value": "{{workspaceId}}" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    }
  ]
}
