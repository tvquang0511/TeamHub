{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    // These two often cause "import/export in CJS" headaches for config files
    "verbatimModuleSyntax": false,
    "noUncheckedSideEffectImports": false
  },
  "include": ["src", "prisma.config.ts", "prisma/**/*.ts"]
}