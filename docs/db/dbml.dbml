// TeamHub DBML (draft) — can paste into dbdiagram.io

Table users {
  id uuid [pk]
  email varchar [unique, not null]
  password_hash varchar [not null]
  display_name varchar [not null]
  created_at timestamp
  updated_at timestamp
}

Table refresh_tokens {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  token_hash varchar [not null]
  expires_at timestamp [not null]
  revoked_at timestamp
  created_at timestamp
}

Table workspaces {
  id uuid [pk]
  name varchar [not null]
  created_at timestamp
  updated_at timestamp
}

Table workspace_members {
  id uuid [pk]
  workspace_id uuid [not null, ref: > workspaces.id]
  user_id uuid [not null, ref: > users.id]
  role varchar [not null] // OWNER | ADMIN | MEMBER
  created_at timestamp

  Indexes {
    (workspace_id, user_id) [unique]
  }
}

Table workspace_invites {
  id uuid [pk]
  workspace_id uuid [not null, ref: > workspaces.id]
  email varchar [not null]
  token varchar [not null, unique]
  expires_at timestamp [not null]
  accepted_at timestamp
  created_at timestamp
}

Table workspace_messages {
  id uuid [pk]
  workspace_id uuid [not null, ref: > workspaces.id]
  sender_id uuid [not null, ref: > users.id]
  content text [not null]
  created_at timestamp

  Indexes {
    (workspace_id, created_at)
  }
}

Table boards {
  id uuid [pk]
  workspace_id uuid [not null, ref: > workspaces.id]
  name varchar [not null]
  description text
  position numeric
  archived_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table lists {
  id uuid [pk]
  board_id uuid [not null, ref: > boards.id]
  name varchar [not null]
  position numeric [not null]
  archived_at timestamp
  created_at timestamp
  updated_at timestamp

  Indexes {
    (board_id, position)
  }
}

Table cards {
  id uuid [pk]
  list_id uuid [not null, ref: > lists.id]
  title varchar [not null]
  description text
  due_at timestamp
  position numeric [not null]
  archived_at timestamp
  created_at timestamp
  updated_at timestamp

  Indexes {
    (list_id, position)
  }
}

Table card_comments {
  id uuid [pk]
  card_id uuid [not null, ref: > cards.id]
  author_id uuid [not null, ref: > users.id]
  content text [not null]
  created_at timestamp
}

Table card_assignees {
  id uuid [pk]
  card_id uuid [not null, ref: > cards.id]
  user_id uuid [not null, ref: > users.id]
  created_at timestamp

  Indexes {
    (card_id, user_id) [unique]
  }
}

Table labels {
  id uuid [pk]
  workspace_id uuid [not null, ref: > workspaces.id]
  name varchar [not null]
  color varchar
  created_at timestamp
}

Table card_labels {
  id uuid [pk]
  card_id uuid [not null, ref: > cards.id]
  label_id uuid [not null, ref: > labels.id]
  created_at timestamp

  Indexes {
    (card_id, label_id) [unique]
  }
}

Table checklists {
  id uuid [pk]
  card_id uuid [not null, ref: > cards.id]
  title varchar [not null]
  position numeric [not null]
  created_at timestamp
}

Table checklist_items {
  id uuid [pk]
  checklist_id uuid [not null, ref: > checklists.id]
  title varchar [not null]
  position numeric [not null]
  is_done boolean [not null, default: false]
  created_at timestamp
}

Table reminder_jobs {
  id uuid [pk]
  card_id uuid [not null, ref: > cards.id]
  user_id uuid [not null, ref: > users.id]
  remind_at timestamp [not null]
  status varchar [not null] // PENDING | SENT | CANCELED | FAILED
  attempts int [not null, default: 0]
  last_error text
  sent_at timestamp
  created_at timestamp

  Indexes {
    (status, remind_at)
    (card_id, user_id, remind_at) [unique]
  }
}

// Optional
Table activities {
  id uuid [pk]
  workspace_id uuid [ref: > workspaces.id]
  board_id uuid [ref: > boards.id]
  card_id uuid [ref: > cards.id]
  actor_id uuid [not null, ref: > users.id]
  type varchar [not null]
  payload json
  created_at timestamp
}