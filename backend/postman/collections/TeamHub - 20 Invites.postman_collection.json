{
  "info": {
    "_postman_id": "a2aa4f1c-5d4b-4d93-9f6f-f8c3f8a8d020",
    "name": "TeamHub - 20 Invites",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4000/api" }],
  "item": [
    {
      "name": "Create workspace invite (captures inviteToken)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/invites/workspaces/{{workspaceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "workspaces", "{{workspaceId}}"]
        },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{inviteEmail}}\",\n  \"role\": \"MEMBER\",\n  \"expiresAt\": \"2026-12-31T00:00:00.000Z\"\n}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.invite && json.invite.token) pm.collectionVariables.set('inviteToken', json.invite.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get invite by token (workspace members)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/{{inviteToken}}",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "{{inviteToken}}"]
        }
      }
    },
    {
      "name": "List workspace invites (OWNER/ADMIN)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/workspaces/{{workspaceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "workspaces", "{{workspaceId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "if (json.invites && json.invites.length) pm.collectionVariables.set('inviteId', json.invites[0].id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Revoke workspace invite (OWNER/ADMIN)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/workspaces/{{workspaceId}}/{{inviteId}}",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "workspaces", "{{workspaceId}}", "{{inviteId}}"]
        }
      }
    },
    {
      "name": "Accept invite as invited user",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{inviteAccessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/{{inviteToken}}/accept",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "{{inviteToken}}", "accept"]
        }
      }
    },
    {
      "name": "Inbox: list my workspace invites",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{inviteAccessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/inbox/workspaces",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "inbox", "workspaces"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "if (json.invites && json.invites.length) pm.collectionVariables.set('inboxInviteId', json.invites[0].invite.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Inbox: accept workspace invite by inviteId",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{inviteAccessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/inbox/workspaces/{{inboxInviteId}}/accept",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "inbox", "workspaces", "{{inboxInviteId}}", "accept"]
        }
      }
    },
    {
      "name": "Inbox: decline workspace invite by inviteId",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{inviteAccessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/invites/inbox/workspaces/{{inboxInviteId}}/decline",
          "host": ["{{baseUrl}}"],
          "path": ["invites", "inbox", "workspaces", "{{inboxInviteId}}", "decline"]
        }
      }
    },
    {
      "name": "Board: add member by email (direct add)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/boards/{{boardId}}/members/by-email",
          "host": ["{{baseUrl}}"],
          "path": ["boards", "{{boardId}}", "members", "by-email"]
        },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{inviteEmail}}\",\n  \"role\": \"MEMBER\"\n}" }
      }
    }
  ]
}
